# Supabase: Project Settings -> Database -> Connect -> ORM Prisma / Connection pooling

# If password contains @ # : / ? etc., URL-encode it (example: my@pwd -> my%40pwd).
# Pooler URI (often port 6543, ?pgbouncer=true) — runtime Prisma Client
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_ENCODED_DB_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# prisma migrate / db push — Session pool port 5432 or direct URI from Dashboard
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_ENCODED_DB_PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Alternative "direct IPv4 only" sometimes shown separately:
# DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

JWT_SECRET="change-me-to-long-random-string"
PORT=8000

# Chay: npm run storage:verify (tao bucket neu chua co)

# Supabase SDK (server-only): Project Settings -> API -> service_role JWT (starts with eyJ...). NEVER use publishable / sb_publishable_* here.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

SUPABASE_STORAGE_BUCKET="review-images"
SUPABASE_BROADCAST_CHANNEL="travel-app"

# --- Đối chiếu với Next.js (App Router / client) ---
# NEXT_PUBLIC_SUPABASE_URL                    -> trùng SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY       -> chỉ client; không thay được SUPABASE_SERVICE_ROLE_KEY cho Storage server-side
