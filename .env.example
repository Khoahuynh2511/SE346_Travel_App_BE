# Supabase: Project Settings -> Database -> Connect -> ORM Prisma / Connection pooling

# If password contains @ # : / ? etc., URL-encode it (example: my@pwd -> my%40pwd).
# Runtime on Render uses Supabase session pooler (IPv4) for Prisma Client.
DATABASE_URL="postgresql://postgres.vlcjgefzqytxrcrehzox:YOUR_ENCODED_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# prisma migrate / db push. Use direct locally if your machine supports IPv6.
DIRECT_URL="postgresql://postgres:YOUR_ENCODED_DB_PASSWORD@db.vlcjgefzqytxrcrehzox.supabase.co:5432/postgres?sslmode=require"

# Alternative "direct IPv4 only" sometimes shown separately:
# DIRECT_URL="postgresql://postgres.vlcjgefzqytxrcrehzox:YOUR_ENCODED_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

JWT_SECRET="change-me-to-long-random-string"
PORT=8000
CORS_ORIGINS="https://se346-travel-app-fe.vercel.app"

# Chay: npm run storage:verify (tao bucket neu chua co)

# Supabase SDK (server-only): Project Settings -> API -> service_role JWT (starts with eyJ...). NEVER use publishable / sb_publishable_* here.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

SUPABASE_STORAGE_BUCKET="review-images"
SUPABASE_BROADCAST_CHANNEL="travel-app"

GROQ_API_KEY="your-groq-api-key"

# Google OAuth Client ID for Google login
# Get from Google Cloud Console -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Firebase Service Account Key (JSON string) for push notifications
# Get from Firebase Console -> Project Settings -> Service Accounts -> Generate Private Key
# Paste the entire JSON content as a single line (replace newlines with \n)
FIREBASE_SERVICE_ACCOUNT_KEY=""
APP_URL="https://se346-travel-app-be.onrender.com"

# --- Đối chiếu với Next.js (App Router / client) ---
# NEXT_PUBLIC_SUPABASE_URL                    -> trùng SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY       -> chỉ client; không thay được SUPABASE_SERVICE_ROLE_KEY cho Storage server-side
