// NOTE: Data validation (rating 1-5, email format, content length) is enforced
// at the application level via Zod schemas in src/routes/*.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlaceCategory {
  ATTRACTIONS
  DINING
  FESTIVALS
  STAYS
  SHOPPING
}

enum PlaceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  TRAVELER
  OWNER
  ADMIN
}

enum TripActivityPeriod {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum TripMemberStatus {
  PENDING
  ACTIVE
  REJECTED
  LEFT
  REMOVED
}

enum NotificationType {
  invited
  upcoming
  promotion
  like_comment
  place_approved
  place_rejected
}

model User {
  id           Int              @id @default(autoincrement())
  email        String           @unique
  passwordHash String
  role         UserRole         @default(TRAVELER)
  fullName     String?
  username     String?          @unique
  location     String?
  avatarUrl    String?
  fcmToken     String?
  isBanned     Boolean          @default(false)
  banReason    String?
  bannedAt     DateTime?
  createdAt    DateTime         @default(now())
  reviews      Review[]
  reviewLikes  ReviewLike[]
  favorites    Favorite[]
  ownedPlaces  Place[]          @relation("PlaceOwner")
  trips        Trip[]
  tripMembers  TripMember[]
  tripInvites  TripMember[]     @relation("TripMemberInviter")
  diaryEntries TripDiaryEntry[]

  reviewedPlaces         Place[]                 @relation("PlaceReviewer")
  actedNotifications     Notification[]          @relation("NotificationActor")
  notificationRecipients NotificationRecipient[]
  chatMessages           ChatMessage[]

  @@index([role])
}

model Place {
  id                     String         @id @default(cuid())
  ownerId                Int?
  name                   String
  region                 String
  category               PlaceCategory
  coverImageUrl          String
  featureLabel           String
  averageRating          Float          @default(0)
  ratingCount            Int            @default(0)
  about                  String         @default("")
  priceLevel             Decimal?       @db.Decimal(10, 2)
  latitude               Float?
  longitude              Float?
  estimatedVisitDuration Int? // minutes, e.g. 120 = 2 hours
  recommendedTimeOfDay   String? // "MORNING", "AFTERNOON", "EVENING", or null = ANY
  status                 PlaceStatus    @default(PENDING)
  rejectionReason        String?
  reviewedAt             DateTime?
  reviewedBy             Int?
  owner                  User?          @relation("PlaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  reviewedByUser         User?          @relation("PlaceReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviews                Review[]
  favorites              Favorite[]
  promotions             Promotion[]
  images                 PlaceImage[]
  hotelTrips             Trip[]         @relation("TripCurrentHotel")
  tripActivities         TripActivity[]

  @@index([category])
  @@index([status])
  @@index([region])
}

model PlaceImage {
  id        String   @id @default(cuid())
  placeId   String
  url       String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Promotion {
  id           String    @id @default(cuid())
  placeId      String
  title        String
  isActive     Boolean   @default(true)
  startDate    String
  endDate      String
  days         String[]
  startTime    String    @default("")
  endTime      String    @default("")
  specificTime Boolean   @default(false)
  activeAt     DateTime?
  createdAt    DateTime  @default(now())
  place        Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model Review {
  id        String        @id @default(cuid())
  placeId   String
  userId    Int
  rating    Int
  content   String
  createdAt DateTime      @default(now())
  place     Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    ReviewImage[]
  likes     ReviewLike[]

  @@index([rating])
  @@index([placeId])
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReviewLike {
  id       Int    @id @default(autoincrement())
  reviewId String
  userId   Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model Favorite {
  userId  Int
  placeId String
  saveAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place   Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@index([saveAt])
}

model Trip {
  id                   String           @id @default(cuid())
  userId               Int
  title                String
  destination          String?
  currentHotelName     String?
  currentHotelPlaceId  String?
  startDate            DateTime
  endDate              DateTime
  budget               Decimal          @default(0) @db.Decimal(12, 2)
  totalBudgetPerPerson Decimal          @default(0) @db.Decimal(12, 2)
  coverImageUrl        String?
  currency             String           @default("VND")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentHotelPlace    Place?           @relation("TripCurrentHotel", fields: [currentHotelPlaceId], references: [id], onDelete: SetNull)
  members              TripMember[]
  days                 TripDay[]
  diaryEntries         TripDiaryEntry[]

  @@index([userId])
  @@index([startDate, endDate])
  @@index([currentHotelPlaceId])
}

model TripMember {
  id               String           @id @default(cuid())
  tripId           String
  userId           Int?
  invitedById      Int?
  name             String?
  avatarUrl        String?
  status           TripMemberStatus @default(PENDING)
  joinedAt         DateTime?
  leftAt           DateTime?
  inviteAcceptedAt DateTime?
  inviteRejectedAt DateTime?
  removedAt        DateTime?
  createdAt        DateTime         @default(now())
  trip             Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  invitedBy        User?            @relation("TripMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([tripId, userId])
  @@index([tripId, status])
  @@index([tripId])
  @@index([userId])
  @@index([invitedById])
  @@index([status])
}

model Notification {
  id         String                  @id @default(cuid())
  type       NotificationType
  actorId    Int?
  targetId   String?
  title      String?
  body       String?
  data       Json?
  createdAt  DateTime                @default(now())
  actor      User?                   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@index([type])
  @@index([targetId])
  @@index([createdAt])
}

model NotificationRecipient {
  id             String       @id @default(cuid())
  notificationId String
  userId         Int
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model TripDay {
  id              String         @id @default(cuid())
  tripId          String
  dayNumber       Int
  title           String?
  date            DateTime
  estimatedBudget Decimal        @default(0) @db.Decimal(12, 2)
  isExpanded      Boolean        @default(true)
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities      TripActivity[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
}

model TripActivity {
  id            String             @id @default(cuid())
  tripDayId     String
  placeId       String?
  title         String
  description   String?
  imageUrl      String?
  period        TripActivityPeriod
  scheduledTime String?
  estimatedCost Decimal            @default(0) @db.Decimal(12, 2)
  rating        Float?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  tripDay       TripDay            @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  place         Place?             @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([tripDayId])
  @@index([placeId])
}

model TripDiaryEntry {
  id           String           @id @default(cuid())
  tripId       String
  userId       Int
  title        String
  content      String
  locationName String?
  occurredAt   DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  trip         Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images       TripDiaryImage[]

  @@index([tripId])
  @@index([userId])
  @@index([occurredAt])
}

model TripDiaryImage {
  id        String         @id @default(cuid())
  entryId   String
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  entry     TripDiaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
