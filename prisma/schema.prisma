generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlaceCategory {
  ATTRACTIONS
  DINING
  FESTIVALS
}

enum UserRole {
  TRAVELER
  OWNER
}

enum TripActivityPeriod {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  role         UserRole     @default(TRAVELER)
  fullName     String?
  username     String?      @unique
  location     String?
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  reviews      Review[]
  reviewLikes  ReviewLike[]
  favorites    Favorite[]
  ownedPlaces  Place[]
  trips        Trip[]
  tripMembers  TripMember[]
}

model Place {
  id             String         @id @default(cuid())
  ownerId        Int?
  name           String
  region         String
  category       PlaceCategory
  coverImageUrl  String
  featureLabel   String
  averageRating  Float          @default(0)
  ratingCount    Int            @default(0)
  about          String         @default("")
  priceLevel     Float?
  latitude       Float?
  longitude      Float?
  owner          User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  reviews        Review[]
  favorites      Favorite[]
  promotions     Promotion[]
  images         PlaceImage[]
  hotelTrips     Trip[]         @relation("TripCurrentHotel")
  tripActivities TripActivity[]
}

model PlaceImage {
  id        String   @id @default(cuid())
  placeId   String
  url       String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Promotion {
  id           String   @id @default(cuid())
  placeId      String
  title        String
  isActive     Boolean  @default(true)
  startDate    String
  endDate      String
  days         String[]
  startTime    String   @default("")
  endTime      String   @default("")
  specificTime Boolean  @default(false)
  createdAt    DateTime @default(now())
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Review {
  id        String        @id @default(cuid())
  placeId   String
  userId    Int
  rating    Int
  content   String
  createdAt DateTime      @default(now())
  place     Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    ReviewImage[]
  likes     ReviewLike[]
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReviewLike {
  id       Int    @id @default(autoincrement())
  reviewId String
  userId   Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model Favorite {
  userId  Int
  placeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
}

model Trip {
  id                   String       @id @default(cuid())
  userId               Int
  title                String
  destination          String?
  currentHotelName     String?
  currentHotelPlaceId  String?
  startDate            DateTime
  endDate              DateTime
  budget               Float        @default(0)
  totalBudgetPerPerson Float        @default(0)
  coverImageUrl        String?
  currency             String       @default("VND")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentHotelPlace    Place?       @relation("TripCurrentHotel", fields: [currentHotelPlaceId], references: [id], onDelete: SetNull)
  members              TripMember[]
  days                 TripDay[]

  @@index([userId])
  @@index([currentHotelPlaceId])
}

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    Int?
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

model TripDay {
  id              String         @id @default(cuid())
  tripId          String
  dayNumber       Int
  title           String?
  date            DateTime
  estimatedBudget Float          @default(0)
  isExpanded      Boolean        @default(true)
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities      TripActivity[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
}

model TripActivity {
  id            String             @id @default(cuid())
  tripDayId     String
  placeId       String?
  title         String
  description   String?
  imageUrl      String?
  period        TripActivityPeriod
  scheduledTime String?
  estimatedCost Float              @default(0)
  rating        Float?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  tripDay       TripDay            @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  place         Place?             @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([tripDayId])
  @@index([placeId])
}
